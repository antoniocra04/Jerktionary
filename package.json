{
  "name": "jerktionary-desktop",
  "version": "0.4.7",
  "description": "Electron desktop frontend for realtime speech transcription, term extraction, and interview-style answers.",
  "license": "MIT",
  "author": "antoniocra04",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/antoniocra04/Jerktionary.git"
  },
  "bugs": {
    "url": "https://github.com/antoniocra04/Jerktionary/issues"
  },
  "homepage": "https://github.com/antoniocra04/Jerktionary#readme",
  "keywords": [
    "electron",
    "react",
    "transcription",
    "whisper",
    "llm",
    "desktop"
  ],
  "type": "module",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "electron-vite -c electron.vite.config.ts dev",
    "build": "tsc --noEmit && electron-vite -c electron.vite.config.ts build",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "build:mac": "npm run build && electron-builder --mac",
    "build:mac:local": "npm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir && npm run sign:mac:adhoc",
    "sign:mac:adhoc": "codesign --force --deep --sign - --entitlements build/entitlements.mac.plist release/mac-arm64/Jerktionary.app",
    "preview": "electron-vite -c electron.vite.config.ts preview",
    "test": "vitest run -c vitest.config.ts",
    "test:watch": "vitest -c vitest.config.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-query": "^5.81.5",
    "clsx": "^2.1.1",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.468.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^4.5.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^15.0.7",
    "@types/node": "^20.19.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.20",
    "jsdom": "^24.1.3",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.5.4",
    "vite": "^5.4.19",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "local.jerktionary.desktop",
    "productName": "Jerktionary",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "files": [
      "out/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "win": {
      "icon": "build/icon.png",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "tar.gz",
        "zip"
      ],
      "category": "Utility"
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "LSUIElement": true,
        "NSMicrophoneUsageDescription": "Для распознавания речи и перевода",
        "NSCameraUsageDescription": "Для распознавания речи и перевода"
      }
    },
    "nsis": {
      "artifactName": "${productName}-${version}-win-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-${version}-win-${arch}-portable.${ext}"
    }
  },
  "allowScripts": {
    "electron@31.7.7": true,
    "esbuild@0.21.5": true
  }
}
